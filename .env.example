# Supabase 环境变量配置示例（不要提交真实密钥到仓库）

# 推荐使用这两个变量（Vite 前端）
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# TinyMCE 富文本编辑器 API Key (免费注册获取: https://www.tiny.cloud/)
# 如果不填会显示 API Key 警告，但不影响基础编辑功能
VITE_TINYMCE_API_KEY=your_tinymce_api_key_here

# 可选：Next.js 或通用命名
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# 本地开发可控制模拟数据
USE_MOCK_DATA=true

# 错误上报服务配置（可选）
# 配置错误监控服务的上报URL，用于收集前端错误信息
# 例如：Sentry、LogRocket等服务的上报端点
VITE_ERROR_REPORT_URL=

# DashScope (通义千问) API 配置
# 获取API密钥: https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here
VITE_QWEN_API_KEY=your_dashscope_api_key_here

# Kimi (Moonshot) API 配置
# 获取API密钥: https://platform.moonshot.cn/
VITE_KIMI_API_KEY=your_kimi_api_key_here
KIMI_API_KEY=your_kimi_api_key_here

# DeepSeek API 配置
# 获取API密钥: https://platform.deepseek.com/
VITE_DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ==========================================
# OAuth 第三方登录配置
# ==========================================

# 微信登录配置
# 获取方式: https://open.weixin.qq.com/
WECHAT_APPID=your_wechat_appid
WECHAT_APPSECRET=your_wechat_appsecret

# 支付宝登录配置
# 获取方式: https://open.alipay.com/
ALIPAY_APPID=your_alipay_appid
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key

# GitHub OAuth 配置
# 获取方式: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth 配置
# 获取方式: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5173/oauth/callback/google

# 应用基础 URL（用于 OAuth 回调）
VITE_APP_URL=http://localhost:5173

# 提示：在本地复制为 .env，并替换为你自己的 Supabase 项目 URL 与匿名密钥
# 安全：不要把真实密钥提交到仓库，保持 .env 仅在本地存在
