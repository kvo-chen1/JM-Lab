# ==========================================
# Neon 数据库配置（主要数据库）
# ==========================================
# 从 Neon 控制台获取数据库连接字符串
# https://console.neon.tech/
DATABASE_URL=postgresql://user:password@host.neon.tech/database
NEON_DATABASE_URL=postgresql://user:password@host.neon.tech/database
POSTGRES_URL=postgresql://user:password@host.neon.tech/database
POSTGRES_URL_NON_POOLING=postgresql://user:password@host.neon.tech/database

# 数据库类型 - 固定为 postgresql
DB_TYPE=postgresql

# ==========================================
# JWT 配置
# ==========================================
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# ==========================================
# AI API 配置
# ==========================================

# DashScope (通义千问) API 配置
# 获取API密钥: https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here
VITE_QWEN_API_KEY=your_dashscope_api_key_here

# Kimi (Moonshot) API 配置
# 获取API密钥: https://platform.moonshot.cn/
VITE_KIMI_API_KEY=your_kimi_api_key_here
KIMI_API_KEY=your_kimi_api_key_here

# DeepSeek API 配置
# 获取API密钥: https://platform.deepseek.com/
VITE_DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ==========================================
# 前端配置
# ==========================================

# TinyMCE 富文本编辑器 API Key (免费注册获取: https://www.tiny.cloud/)
VITE_TINYMCE_API_KEY=your_tinymce_api_key_here

# 本地开发 API 配置
VITE_LOCAL_API_URL=http://localhost:3023
VITE_USE_LOCAL_PROXY=true

# ==========================================
# OAuth 第三方登录配置
# ==========================================

# 微信登录配置
WECHAT_APPID=your_wechat_appid
WECHAT_APPSECRET=your_wechat_appsecret

# 支付宝登录配置
ALIPAY_APPID=your_alipay_appid
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key

# GitHub OAuth 配置
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth 配置
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5173/oauth/callback/google

# 应用基础 URL（用于 OAuth 回调）
VITE_APP_URL=http://localhost:5173

# ==========================================
# 可选配置
# ==========================================

# 本地开发可控制模拟数据
USE_MOCK_DATA=false

# ==========================================
# Sentry 错误监控配置
# ==========================================
# 获取 Sentry DSN: https://sentry.io/
VITE_SENTRY_DSN=https://your-sentry-dsn-here.ingest.sentry.io/project-id

# 应用版本号（用于错误追踪）
VITE_APP_VERSION=0.0.8

# ==========================================
# Supabase 配置（已禁用，使用 Neon 数据库替代）
# ==========================================
# 注意：平台现在只使用 Neon 数据库
# 以下配置仅用于兼容性，指向本地代理
VITE_SUPABASE_URL=http://localhost:3023/api/db
VITE_SUPABASE_ANON_KEY=local-proxy-key
VITE_SUPABASE_SERVICE_ROLE_KEY=local-proxy-key
