# 个人收款码支付配置
# 复制此文件为 .env.local 并填入真实配置

# ==================== 微信支付个人收款码 ====================
# 是否启用微信支付个人收款码
PERSONAL_WECHAT_ENABLED=true

# 微信收款码图片URL（上传到图床或CDN的地址）
PERSONAL_WECHAT_QR_CODE=https://your-cdn.com/wechat-qr-code.png

# 微信收款人姓名
PERSONAL_WECHAT_NAME=您的姓名

# 微信账号（可选）
PERSONAL_WECHAT_ACCOUNT=your_wechat_id

# ==================== 支付宝个人收款码 ====================
# 是否启用支付宝个人收款码
PERSONAL_ALIPAY_ENABLED=true

# 支付宝收款码图片URL
PERSONAL_ALIPAY_QR_CODE=https://your-cdn.com/alipay-qr-code.png

# 支付宝收款人姓名
PERSONAL_ALIPAY_NAME=您的姓名

# 支付宝账号（可选）
PERSONAL_ALIPAY_ACCOUNT=your_phone_or_email

# ==================== 支付审核配置 ====================
# 是否开启自动审核（根据订单号匹配）
PERSONAL_PAYMENT_AUTO_VERIFY=false

# 管理员通知方式（email, sms, webhook）
PERSONAL_PAYMENT_NOTIFY=email

# 管理员邮箱（用于接收支付通知）
ADMIN_EMAIL=admin@your-domain.com
