import React from 'react';
import { useTheme } from '@/hooks/useTheme';
import { useCreateStore } from '../hooks/useCreateStore';

export default function CanvasArea() {
  const { isDark } = useTheme();
  const { activeTool } = useCreateStore();

  return (
    <div className={`flex-1 flex flex-col relative transition-colors ${isDark ? 'bg-gray-950' : 'bg-gray-50'}`}>
      <div className="flex items-center justify-center h-full">
        <div className="text-center">
          <h2 className={`text-xl font-bold ${isDark ? 'text-white' : 'text-gray-900'}`}>
            Canvas Area ({activeTool})
          </h2>
          <p className="text-gray-500 mt-2">
            The original canvas component has a syntax error and has been temporarily replaced.
          </p>
        </div>
      </div>
    </div>
  );
}
